# ── Famly Credentials ────────────────────────────────────────────────────
# Your Famly parent account email and password.
# The app logs in automatically and refreshes the token on 401/403.
FAMLY_EMAIL=parent@example.com
FAMLY_PASSWORD=your-famly-password

# Your child's UUID (visible in the Famly app URL or API responses)
FAMLY_CHILD_ID=12345-ecc6-4128-a491-a1b2c3d4e5f6

# ── Backend ──────────────────────────────────────────────────────────────
# Famly backend base URL. Default works for app.famly.co. Other Famly-based
# portals (e.g. Bright Horizons UK) need to override this.
# FAMLY_BASE_URL=https://app.famly.co
# FAMLY_BASE_URL=https://familyapp.brighthorizons.co.uk

# ── Host Paths (used by docker-compose for volume mounts) ──────────────
# Host path to photo storage — any local or network-mounted directory
# Examples: /home/user/famly-photos, /mnt/nas/photos, /volume1/photos
HOST_PHOTOS_PATH=/path/to/your/photos

# ── Container Paths ────────────────────────────────────────────────────
# Where to save downloaded photos (inside the container)
PHOTO_DIR=/photos

# ── Schedule ─────────────────────────────────────────────────────────────
# How often to check for new photos (in hours)
FETCH_INTERVAL_HOURS=6

# ── Content Sources ──────────────────────────────────────────────────────
FETCH_TAGGED=true
FETCH_JOURNEY=true
# Feed, notes, and messages can also be fetched but have no UI yet:
# FETCH_FEED=false
# FETCH_NOTES=false
# FETCH_MESSAGES=false

# ── App ──────────────────────────────────────────────────────────────────
APP_PORT=8811
LOG_LEVEL=INFO

# Password required for Purge & Redownload (leave empty to disable)
ADMIN_PASSWORD=
